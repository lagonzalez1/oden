{# ── Node Definitions ─────────────────────────────────────── #}
NODES:
  (:Person)
      name             : string  — full filer name e.g. "Hon. Nancy Pelosi"
      status           : string  — "Member" | "Spouse" | "Dependent"
      state_district   : string  — e.g. "CA11"
      last_updated     : datetime

  (:Asset)
      ticker           : string  — unique identifier e.g. "GOOGL"
      type             : string  — "ST" | "OP" | "OT"

  (:Issuer)
      name             : string  — legal entity name e.g. "Alphabet Inc Class A Common"

  (:Transaction)
      id               : string  — UUID
      doc_id           : string  — filing ID e.g. "20033725"
      type             : string  — "P" (Purchase) | "S" (Sale) | "E" (Exchange)
      trade_date       : date    — e.g. date("2026-01-16")
      amount_range     : string  — lower bound integer as string e.g. "500001"
      description      : string  — raw description text, may be null
      created_at       : datetime

  (:Derivative:CallOption)
      contract_id      : string  — "{ticker}-{strike}-{expiry}"
      strike_price     : float   — e.g. 150.0
      expiration_date  : date

{# ── Relationship Definitions ────────────────────────────── #}
RELATIONSHIPS:
  (Person)-[:EXECUTED]->(Transaction)         — person performed this transaction
  (Transaction)-[:INVOLVES]->(Asset)          — transaction is on this asset
  (Asset)-[:ISSUED_BY]->(Issuer)              — asset belongs to this issuer
  (Transaction)-[:OF_DERIVATIVE]->(Derivative)— transaction is on a derivative contract
  (Derivative)-[:UNDERLYING_ASSET]->(Asset)   — derivative is based on this asset

{# ── Query Rules ─────────────────────────────────────────── #}
STRICT RULES:
  1. Only use nodes, relationships, and properties defined above — never invent new ones.
  2. Always use parameterised values with $ prefix e.g. $ticker, $name, $date.
  3. For date comparisons use date() e.g. date("2026-01-01").
  4. For amount_range comparisons, cast to integer: toInteger(t.amount_range) > $amount.
  5. Always alias RETURN fields with AS e.g. RETURN p.name AS filer_name.
  6. Use OPTIONAL MATCH when a relationship may not exist (e.g. Derivative).
  7. Never use MERGE or CREATE — output SELECT (MATCH) queries only.
